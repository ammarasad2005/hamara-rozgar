# Hamara Rozgar - Environment Configuration Template
# Copy this file to .env and configure your secret credentials.

# Orchestration Configuration
# Options for VITE_NLP_ENGINE: github (default), regex, ollama, groq
VITE_NLP_ENGINE=github
# Options for VITE_MAP_ENGINE: osm (default), offline
VITE_MAP_ENGINE=osm

# 🤖 Groq Cloud AI Engine (Free & Fast open-source LLMs)
VITE_GROQ_API_KEY=""

# 🤖 GitHub Models API (High-Fidelity models like gpt-4o-mini, gpt-4o, Llama-3)
VITE_GITHUB_TOKEN=""
VITE_GITHUB_MODEL="gpt-4o-mini"

# 🤖 Ollama local server (Fully self-hosted NLP)
VITE_OLLAMA_URL="http://localhost:11434"
VITE_OLLAMA_MODEL="llama3"

# ⚡ Supabase Database Backend (Zero-SDK REST sync)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
